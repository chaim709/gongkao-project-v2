# 应用配置
APP_NAME=公考管理系统 V2
APP_VERSION=2.0.0
DEBUG=True

# 数据库配置
DATABASE_URL=postgresql+asyncpg://gongkao_user:gongkao_pass@localhost:5432/gongkao_db

# JWT 配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 配置（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
